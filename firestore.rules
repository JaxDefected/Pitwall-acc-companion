rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // ID validation to prevent system resource poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Setup validation schema
    function isValidSetup(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 128
          && data.car is string && data.car.size() <= 128
          && data.track is string && data.track.size() <= 128
          && data.notes is string && data.notes.size() <= 1000
          && data.uploadedBy is string && data.uploadedBy == request.auth.uid
          && data.uploadedByName is string && data.uploadedByName.size() <= 128;
    }

    // Guide validation schema
    function isValidGuide(data) {
      return data.id is string && data.id.size() <= 128
          && data.content is string && data.content.size() <= 50000;
    }

    // Setup collection rules
    match /setups/{setupId} {
      // Anyone can read setups, creating a seamless public/group sharing workflow
      allow read, list: if true; 
      
      allow create: if isSignedIn() 
                    && isValidId(setupId) 
                    && isValidSetup(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
                    
      allow update: if isSignedIn()
                    && isValidId(setupId)
                    && isValidSetup(incoming())
                    && incoming().uploadedBy == existing().uploadedBy
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
                    
      allow delete: if isSignedIn()
                    && isValidId(setupId)
                    && existing().uploadedBy == request.auth.uid;
    }

    // Guides collection rules
    match /guides/{guideId} {
      allow read: if true; 
      
      allow create: if isSignedIn()
                    && isValidId(guideId)
                    && isValidGuide(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
                    && isValidId(guideId)
                    && isValidGuide(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
                            
      allow delete: if isSignedIn()
                    && isValidId(guideId);
    }

    // Driver Users Profile Rules
    match /users/{uid} {
      allow read: if true;
      allow create, update: if isSignedIn() 
                            && request.auth.uid == uid
                            && incoming().uid == uid
                            && incoming().username is string
                            && incoming().username.size() >= 3
                            && incoming().username.size() <= 32;
      allow delete: if false; // Profiles are locked down
    }

    // Saved Custom Tweaked Setups Rules
    match /savedSetups/{savedSetupId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && isValidId(savedSetupId)
                    && incoming().id == savedSetupId
                    && incoming().authorUsername is string;
      allow update: if isSignedIn()
                    && isValidId(savedSetupId)
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn()
                    && isValidId(savedSetupId);
    }

    // Setup Community Dynamic Ratings & Handling Tags Rules
    match /setupRatings/{ratingId} {
      allow read: if true;
      allow create, update: if isSignedIn()
                            && isValidId(ratingId)
                            && incoming().id == ratingId
                            && incoming().rating >= 1
                            && incoming().rating <= 5;
      allow delete: if isSignedIn()
                    && isValidId(ratingId);
    }
  }
}
